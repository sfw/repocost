# GitHub Personal Access Token (optional but recommended)
# Without it: 60 requests/hour (shared server IP)
# With it: 5,000 requests/hour
# Create at: https://github.com/settings/tokens → Fine-grained → Public repos (read-only)
GITHUB_TOKEN=

# Your deployed URL (used for OG image URLs)
NEXT_PUBLIC_URL=https://repocost.dev
